# SQLite persistence
DATABASE_PATH=data/bias_analysis.sqlite3
RUN_ARTIFACTS_DIR=data/run_artifacts
RUN_ARTIFACTS_ENABLED=true
RUN_ARTIFACTS_PRETTY_JSON=true

# Run defaults
SCHOLARLY_SOURCES=openalex,semantic_scholar,scopus,core
ENRICHMENT_PROVIDER_ORDER=openalex,semantic_scholar,scopus,core
ENRICHMENT_ENABLED_PROVIDERS=openalex,semantic_scholar,scopus,core

# OpenRouter llm_audit execution
OPENROUTER_ENABLED=true
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=bias-analysis
OPENROUTER_SITE_URL=http://localhost:4200
OPENROUTER_MODEL_DISCOVERY_ENDPOINT=user
OPENROUTER_MODEL_DISCOVERY_TTL_SECONDS=300
OPENROUTER_AVAILABLE_MODELS=openrouter/auto,openai/gpt-4.1-mini,openai/o4-mini,openai/gpt-5.4,google/gemini-2.5-flash,google/gemini-2.5-pro,anthropic/claude-haiku-4.5,anthropic/claude-sonnet-4.5,anthropic/claude-opus-4.1
OPENROUTER_DEFAULT_MODELS=openai/gpt-4.1-mini,google/gemini-2.5-flash,anthropic/claude-haiku-4.5
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_MAX_RETRIES=3
OPENROUTER_MAX_TOKENS=1400
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_TOP_P=1.0

# OpenAlex
OPENALEX_API_KEY=
OPENALEX_BASE_URL=https://api.openalex.org
OPENALEX_TIMEOUT_SECONDS=20
OPENALEX_MAX_RETRIES=3
OPENALEX_CACHE_TTL_SECONDS=86400

# Semantic Scholar collection + enrichment
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
SEMANTIC_SCHOLAR_TIMEOUT_SECONDS=20
SEMANTIC_SCHOLAR_MAX_RETRIES=3
SEMANTIC_SCHOLAR_CACHE_TTL_SECONDS=86400

# Scopus collection + enrichment
SCOPUS_API_KEY=
SCOPUS_INSTTOKEN=
SCOPUS_BASE_URL=https://api.elsevier.com
SCOPUS_TIMEOUT_SECONDS=20
SCOPUS_MAX_RETRIES=3
SCOPUS_CACHE_TTL_SECONDS=86400

# CORE collection + enrichment
CORE_API_KEY=
CORE_API_BASE_URL=https://api.core.ac.uk/v3
CORE_TIMEOUT_SECONDS=20
CORE_MAX_RETRIES=3
CORE_CACHE_TTL_SECONDS=86400
